<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle" >
    <corners
        android:topLeftRadius="3dp"
        android:topRightRadius="3dp"
        android:bottomLeftRadius="3dp"
        android:bottomRightRadius="3dp"/>
    <gradient
        android:angle="45"
        android:centerX="35%"
        android:centerColor="@color/color_fondo"
        android:startColor="@color/color_fondo"
        android:endColor="@color/color_fondo"
        android:type="linear"/>
    <padding
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp"/>
    <stroke
        android:width="1dp"
        android:color="@color/color_fondo"/>
</shape>