<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <ImageView
            android:id="@+id/ivLogo_"
            android:layout_width="120dp"
            android:layout_height="160dp"
            android:scaleType="fitXY"
            tools:src="@mipmap/ic_launcher"
            />

        <TextView
            android:id="@+id/tvstars_"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableLeft="@drawable/ic_baseline_stars_24"
            android:layout_marginTop="4dp"
            android:textColor="@color/color_negro"
            android:textSize="14sp"
            />

        <TextView
            android:id="@+id/tvtitle_"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/color_negro"
            android:textSize="14sp"
            />

        <TextView
            android:id="@+id/tvinfo_"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|right"
            android:drawableRight="@android:drawable/ic_menu_info_details"
            android:layout_marginTop="4dp"
            />
    </LinearLayout>
</androidx.cardview.widget.CardView>