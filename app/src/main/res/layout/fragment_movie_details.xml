<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Fragments.MovieDetailsFragment">

    <TextView
        android:id="@+id/tv_back"
        android:layout_width="@dimen/layout_width_moviedetails"
        android:layout_height="@dimen/layout_height_moviedetails"
        android:layout_marginStart="@dimen/layout__marginStart_moviedetails"
        android:background="@drawable/btn_icon_back"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/titulo_ppal"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.02" />

    <TextView
        android:id="@+id/titulo_ppal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/layout_height_moviedetails"
        android:layout_marginStart="@dimen/layout__marginStart_moviedetails"
        android:layout_marginEnd="@dimen/layout_marginEnd_moviedetails"
        android:fontFamily="@font/robotobold"
        android:gravity="center"
        android:textColor="@color/color_negro"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.02"
        tools:text="Queens Gambit" />

    <TextView
        android:id="@+id/tvVertical"
        android:layout_width="8dp"
        android:layout_height="30dp"
        android:background="@drawable/vertical"
        android:textSize="@dimen/textSize_moviedetails"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titulo_ppal"
        app:layout_constraintVertical_bias="0.03" />

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="215dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/robotobold"
        android:textColor="@color/color_negro"
        android:textSize="@dimen/textSize_moviedetails"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.07"
        app:layout_constraintStart_toEndOf="@+id/tvVertical"
        app:layout_constraintTop_toBottomOf="@+id/titulo_ppal"
        app:layout_constraintVertical_bias="0.03"
        tools:text="Gambito de Dama">
    </TextView>

    <TextView
        android:id="@+id/tvSegundoTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/robotoregular"
        android:textColor="@color/color_gris_claro"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.33"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitulo"
        app:layout_constraintVertical_bias="0.03"
        tools:text="The queens Gambit (título original)">

    </TextView>

    <TextView
        android:id="@+id/tipo_pelicula"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="308dp"
        android:fontFamily="@font/robotoregular"
        android:textColor="@color/color_gris_claro"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.382"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSegundoTitulo"
        app:layout_constraintVertical_bias="0.0"
        tools:text="Mini Serie de TV 2020 - 2020 16" />


    <ImageView
        android:id="@+id/video_play"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tipo_pelicula"
        app:layout_constraintVertical_bias="0.065"
        tools:src="@drawable/gamb" />

    <ImageView
        android:id="@+id/imvPlay"
        android:layout_width="100dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_baseline_play_circle_outline_24"
        app:layout_constraintBottom_toBottomOf="@+id/video_play"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/video_play"
        app:layout_constraintTop_toTopOf="@+id/video_play">
    </ImageView>

    <ImageView
        android:id="@+id/imagen_miniatura"
        android:layout_width="90dp"
        android:layout_height="120dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.05"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/video_play"
        app:layout_constraintVertical_bias="0.05"
        tools:src="@drawable/gambito">
    </ImageView>

    <TextView
        android:id="@+id/genero_pelicula"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/background_genero"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:textColor="@color/color_gris_claro"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.081"
        app:layout_constraintStart_toEndOf="@+id/imagen_miniatura"
        app:layout_constraintTop_toBottomOf="@+id/video_play"
        app:layout_constraintVertical_bias="0.035"
        tools:text="Drama" />


    <TextView
        android:id="@+id/tvStars"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginBottom="188dp"
        android:background="@drawable/ic_baseline_stars_24"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.109"
        app:layout_constraintStart_toEndOf="@+id/genero_pelicula"
        app:layout_constraintTop_toBottomOf="@+id/video_play"
        app:layout_constraintVertical_bias="0.12" />

    <TextView
        android:id="@+id/calificacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="120dp"
        android:textColor="@color/color_gris_claro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.1"
        app:layout_constraintStart_toEndOf="@+id/tvStars"
        app:layout_constraintTop_toBottomOf="@+id/video_play"
        app:layout_constraintVertical_bias="0.05"
        tools:text="5.0" />

    <TextView
        android:id="@+id/sinopsis"
        android:layout_width="244dp"
        android:layout_height="83dp"
        android:fontFamily="@font/robotobold"
        android:textColor="@color/color_gris_oscuro"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.3"
        app:layout_constraintStart_toEndOf="@+id/imagen_miniatura"
        app:layout_constraintTop_toBottomOf="@+id/video_play"
        app:layout_constraintVertical_bias="0.18"
        tools:text="@tools:sample/lorem/random" />

    <TextView
        android:id="@+id/divisor_medio"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/fragment_bg_color"
        android:gravity="center"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sinopsis"
        app:layout_constraintVertical_bias="0.1"
        tools:layout_editor_absoluteX="0dp" />

    <TextView
        android:id="@+id/tvGuia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/robotobold"
        android:text="@string/gu_a_de_episodios"
        android:textColor="@color/color_negro"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.056"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/divisor_medio"
        app:layout_constraintVertical_bias="0.1" />


    <TextView
        android:id="@+id/tvcantidad_capitulos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/color_gris_claro"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.73"
        app:layout_constraintStart_toEndOf="@+id/tvGuia"
        app:layout_constraintTop_toBottomOf="@+id/divisor_medio"
        app:layout_constraintVertical_bias="0.129"
        tools:text="7 episodios" />

    <ImageView
        android:id="@+id/tvNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:src="@drawable/ic_baseline_navigate_next_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/tvcantidad_capitulos"
        app:layout_constraintTop_toBottomOf="@+id/divisor_medio"
        app:layout_constraintVertical_bias="0.1">
    </ImageView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAgregar"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:background="@drawable/amarillo_background"
        android:fontFamily="@font/robotobold"
        android:paddingHorizontal="15dp"
        android:text="@string/agregar_a_la_lista_de_seguimiento"
        android:textAllCaps="false"
        android:textColor="@color/color_gris_oscuro"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.6"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/divisor_medio" />


</androidx.constraintlayout.widget.ConstraintLayout>