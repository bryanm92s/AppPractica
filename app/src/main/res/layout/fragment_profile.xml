<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        tools:context=".Fragments.ProfileFragment">

        <LinearLayout
            android:id="@+id/DatosPersonales"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="30dp"
            >
            <com.google.android.material.imageview.ShapeableImageView
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                android:src="@drawable/profile"
                app:shapeAppearance="@style/ImagenRedondeada"
                />
            <TextView
                android:id="@+id/NombreUsuario"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_start_perfil"
                android:fontFamily="@font/robotobold"
                android:textColor="@color/color_negro"
                tools:text="Juan Pérez"
                android:textSize="20sp"
                />
            <ImageView
                android:id="@+id/Configuracion"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_baseline_settings_24" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/card1"
            app:cardElevation="0dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            android:layout_marginHorizontal="30dp"
            app:layout_constraintTop_toBottomOf="@id/DatosPersonales"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_gris_claro">

            </TextView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/reciclerView_operaciones"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/margin_top_perfil"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_operaciones_horizontal">
            </androidx.recyclerview.widget.RecyclerView>


        </androidx.cardview.widget.CardView>


        <androidx.cardview.widget.CardView
            app:cardElevation="0dp"
            android:id="@+id/card2"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/card1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:background="@color/fragment_bg_color"
                />

            <LinearLayout
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/card2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout

                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_top_perfil"
                    android:layout_marginHorizontal="45dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="8dp"
                        android:layout_height="30dp"
                        android:background="@drawable/vertical"
                        android:textSize="25sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_start_perfil"
                        android:fontFamily="@font/robotobold"
                        android:textColor="@color/color_negro"
                        android:textSize="20sp"
                        android:text="@string/lista_de_seguimiento" />
                </LinearLayout>
                <TextView
                    android:id="@+id/Crea_Una_Lista"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_top_perfil"
                    android:layout_marginHorizontal="45dp"
                    android:paddingEnd="10dp"
                    android:text="@string/crea_una_lista_de_seguimiento_para_no_perderte_ninguna_pel_cula_o_serie_de_tv"
                    />
                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="45dp"
                    app:layout_constraintTop_toBottomOf="@id/Crea_Una_Lista"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/amarillo_background"
                    android:text="@string/empieza_tu_lista_de_seguimiento"
                    android:textAllCaps="false"
                    android:textColor="@color/color_gris_oscuro"
                    android:fontFamily="@font/robotobold"
                    android:textSize="19sp"
                    />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            app:cardElevation="0dp"
            android:id="@+id/card3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/card2"
            >

            <TextView
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:background="@color/fragment_bg_color"
                />

            <LinearLayout
                android:id="@+id/contenedor_vistas_recientes"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                app:layout_constraintTop_toBottomOf="@id/card3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="45dp"
                    android:layout_marginTop="@dimen/margin_top_perfil"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="8dp"
                        android:layout_height="30dp"
                        android:background="@drawable/vertical"
                        android:textSize="25sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_start_perfil"
                        android:fontFamily="@font/robotobold"
                        android:textColor="@color/color_negro"
                        android:textSize="20sp"
                        android:text="@string/vistas_recientes" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="45dp"
                    android:layout_marginTop="@dimen/margin_top_perfil"
                    android:paddingEnd="15dp"
                    android:text="No has visitado ninguna página recientemente."
                    />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card4"
            app:cardElevation="0dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/card3"
            >

            <TextView
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:background="@color/fragment_bg_color"
                />

            <LinearLayout
                android:id="@+id/contenedor_favoritos"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                app:layout_constraintTop_toBottomOf="@id/card4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="45dp"
                    android:layout_marginTop="@dimen/margin_top_perfil"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="8dp"
                        android:layout_height="30dp"
                        android:background="@drawable/vertical"
                        android:textSize="25sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_start_perfil"
                        android:fontFamily="@font/robotobold"
                        android:textColor="@color/color_negro"
                        android:textSize="20sp"
                        android:text="@string/personas_favoritas" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="45dp"
                    android:layout_marginTop="@dimen/margin_top_perfil"
                    android:paddingEnd="15dp"
                    android:text="No has agregado ninguna persona recientemente."
                    />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>